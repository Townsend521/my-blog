&lt;td&gt;美国&lt;/td&gt;
&lt;td&gt;MWIR&lt;/td&gt;
&lt;td&gt;早期识别喷流&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;化学剂侦察&lt;/td&gt;
&lt;td&gt;北约&lt;/td&gt;
&lt;td&gt;UV-DIAL&lt;/td&gt;
&lt;td&gt;远距识别&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;烟幕/伪装识别&lt;/td&gt;
&lt;td&gt;欧盟&lt;/td&gt;
